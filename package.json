{
	"name": "obsidian-tag-aliases",
	"version": "0.1.3",
	"description": "Obsidian plugin for defining tag aliases. Normalizes tags at input time by suggesting primary tags when aliases are typed.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "jest"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"tag",
		"alias",
		"tag-management"
	],
	"author": "majiajun",
	"license": "MIT",
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"jest": "^30.3.0",
		"obsidian": "latest",
		"ts-jest": "^29.4.6",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	}
}
